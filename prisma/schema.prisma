// Schéma Prisma — Cockpit Lynova
// Source de vérité métier (prospection) + cache des snapshots financiers.
// Étape 1 : socle minimal (utilisateurs + rôles). Les modèles prospection (§6)
// et finance (§4.4 / §5) seront ajoutés aux étapes 4 à 6.
//
// La DB est Postgres (Supabase). L'app utilise la connexion « poolée » (DATABASE_URL,
// PgBouncer port 6543) ; les migrations utilisent la connexion directe (DIRECT_URL, 5432).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Rôles applicatifs (RBAC §3). Cloisonnement vérifié CÔTÉ SERVEUR dans chaque route.
enum Role {
  DIRIGEANT
  COMMERCIAL
}

/// Profil applicatif d'un utilisateur.
/// `id` = identifiant Supabase Auth (auth.users.id) : l'authentification (magic link)
/// est gérée par Supabase ; cette table porte le rôle et les métadonnées métier.
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  role      Role     @default(COMMERCIAL)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_user")
}

/// Journal des demandes de magic link — sert au rate limiting (§3, §8 : anti-abus / anti-spam).
model MagicLinkRequest {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  ip        String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
  @@map("magic_link_request")
}

// ───────────────────────── Facturation Evoliz (§5) ─────────────────────────
// Cache local en lecture seule des factures et avoirs Evoliz, rafraîchi par sync
// (pas d'appel API à chaque page). Les montants HT/TTC sont stockés tels quels.

enum EvolizDocKind {
  INVOICE // facture
  CREDIT // avoir (note de crédit)
}

/// Une facture OU un avoir Evoliz (typé par `kind`). Source : API Evoliz.
model EvolizDocument {
  id             String        @id @default(uuid()) @db.Uuid
  kind           EvolizDocKind
  evolizId       Int // invoiceid / creditid côté Evoliz
  documentNumber String?
  documentDate   DateTime
  clientId       Int?
  clientName     String?
  totalHt        Decimal       @db.Decimal(12, 2) // total.vat_exclude (HT)
  totalTtc       Decimal       @db.Decimal(12, 2) // total.vat_include (TTC)
  paid           Decimal       @default(0) @db.Decimal(12, 2)
  netToPay       Decimal       @default(0) @db.Decimal(12, 2)
  status         String?
  enabled        Boolean       @default(true) // false = document annulé (hors CA)
  invoiceRef     String? // pour un avoir : numéro de la facture créditée (champ invoice_ref)
  included       Boolean       @default(true) // compte dans le CA (validé, non brouillon, hors avoir d'annulation)
  syncedAt       DateTime      @default(now())

  @@unique([kind, evolizId])
  @@index([documentDate])
  @@index([included])
  @@map("evoliz_document")
}

/// Un achat fournisseur Evoliz (GET /buys). Sert au calcul de la marge commerciale.
model EvolizBuy {
  id             String          @id @default(uuid()) @db.Uuid
  evolizId       Int             @unique // buyid
  documentNumber String?
  documentDate   DateTime
  supplierId     Int?
  supplierName   String?
  totalHt        Decimal         @db.Decimal(12, 2) // total.vat_exclude
  status         String?
  enabled        Boolean         @default(true)
  included       Boolean         @default(true) // compté dans les charges (non annulé / non brouillon)
  syncedAt       DateTime        @default(now())
  items          EvolizBuyItem[]

  @@index([documentDate])
  @@map("evoliz_buy")
}

/// Ligne d'un achat, ventilée par catégorie d'achat Evoliz (purchase_classification).
model EvolizBuyItem {
  id            String    @id @default(uuid()) @db.Uuid
  buyId         String    @db.Uuid
  buy           EvolizBuy @relation(fields: [buyId], references: [id], onDelete: Cascade)
  categoryCode  String?
  categoryLabel String?
  ht            Decimal   @db.Decimal(12, 2) // item.total.vat_exclude (ou rabattu si absent)
  fallback      Boolean   @default(false) // true = HT rabattu (item sans montant individuel)

  @@index([buyId])
  @@map("evoliz_buy_item")
}

/// État de synchronisation d'une source externe (Evoliz, Revolut…).
model SyncState {
  source     String    @id // "evoliz", "revolut"…
  lastSyncAt DateTime?
  detail     String? // résumé JSON de la dernière synchro
  updatedAt  DateTime  @updatedAt

  @@map("sync_state")
}

// ───────────────────────── Prospection native (§6) ─────────────────────────
// Remplace Trello. Accessible aux deux rôles (lecture + écriture). Pas de
// suppression physique : archivage logique (`archived`). Labels & journal
// d'activité (audit) viendront dans une sous-étape ultérieure.

/// Un pipeline commercial (kanban). Ex. « Pipe et ventes ».
model Pipeline {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stages    Stage[]

  @@map("pipeline")
}

/// Colonne du kanban. `kind` (meet/warm/hot/cold/low/won/lost) sert au style
/// et au calcul du taux de transformation.
model Stage {
  id         String     @id @default(uuid()) @db.Uuid
  pipelineId String     @db.Uuid
  pipeline   Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name       String
  kind       String?
  position   Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  prospects  Prospect[]

  @@index([pipelineId, position])
  @@map("pipeline_stage")
}

/// Une carte du kanban : un prospect à un instant donné dans une colonne.
model Prospect {
  id           String    @id @default(uuid()) @db.Uuid
  stageId      String    @db.Uuid
  stage        Stage     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  groupId      String?   @db.Uuid
  group        Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  name         String
  company      String?
  contact      String?
  phone        String?
  email        String?
  reminderAt   DateTime?
  reminderDone Boolean   @default(false)
  dealValue    Decimal?  @db.Decimal(12, 2)
  notes        String?
  position     Float     @default(0)
  archived     Boolean   @default(false)
  createdById  String?   @db.Uuid
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  comments     Comment[]

  @@index([stageId, position])
  @@index([groupId])
  @@map("prospect")
}

/// Groupe d'entreprises (réseau, enseigne…). Un prospect appartient à 0 ou 1 groupe.
model Group {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  color     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  prospects Prospect[]

  @@map("prospect_group")
}

/// Commentaire horodaté et signé sur un prospect (auteur dénormalisé pour l'affichage).
model Comment {
  id         String   @id @default(uuid()) @db.Uuid
  prospectId String   @db.Uuid
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  authorId   String?  @db.Uuid
  authorName String?
  body       String
  createdAt  DateTime @default(now())

  @@index([prospectId, createdAt])
  @@map("prospect_comment")
}
