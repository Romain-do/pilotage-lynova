# =============================================================================
# Cockpit Lynova — variables d'environnement (modèle)
# Copier ce fichier en .env.local et remplir les valeurs. NE JAMAIS committer .env.local.
# Sur Vercel : déclarer ces variables dans Project Settings > Environment Variables.
# =============================================================================

# --- Base de données Postgres (Supabase) -------------------------------------
# DATABASE_URL = connexion POOLÉE (PgBouncer, port 6543) utilisée par l'app.
#   Supabase > Project Settings > Database > Connection string > "Transaction" pooler.
#   Ajouter ?pgbouncer=true&connection_limit=1 à la fin.
DATABASE_URL=
# DIRECT_URL = connexion DIRECTE (port 5432) utilisée par les migrations Prisma.
DIRECT_URL=

# --- Supabase Auth (magic link) ----------------------------------------------
# Supabase > Project Settings > API Keys (nouvelles clés API).
NEXT_PUBLIC_SUPABASE_URL=
# Clé "publishable" (sb_publishable_…, ex-"anon") — exposée au navigateur.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Clé "secret" (sb_secret_…, ex-"service_role") — côté serveur uniquement (admin §3).
SUPABASE_SECRET_KEY=

# Adresse d'expédition des e-mails (magic link). Configurer Resend comme SMTP
# custom dans Supabase > Authentication > Emails pour utiliser ce domaine.
EMAIL_FROM=cockpit@lynova.net

# URL publique du site (fallback pour le lien magique si l'en-tête Origin manque).
# Ex. http://localhost:3000 en local, https://cockpit.lynova.net en prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Seed des premiers comptes (script npm run seed:users) -------------------
SEED_DIRIGEANT_EMAIL=romain@lynova.net
SEED_DIRIGEANT_NAME=Romain
# Renseigner pour créer aussi le compte de Méganne (COMMERCIAL) :
SEED_COMMERCIAL_EMAIL=
SEED_COMMERCIAL_NAME=Méganne

# --- Evoliz (facturation, lecture seule) — étape 5 ---------------------------
EVOLIZ_PUBLIC_KEY=
EVOLIZ_SECRET_KEY=
EVOLIZ_COMPANY_ID=51987

# --- Revolut Business (trésorerie, lecture seule) — étape 6 ------------------
REVOLUT_CLIENT_ID=
REVOLUT_ISS=
# Clé privée PEM sur une seule ligne (remplacer les sauts de ligne par \n).
REVOLUT_PRIVATE_KEY=
REVOLUT_REFRESH_TOKEN=

# --- Trello (import unique de la prospection) — étape 4 ----------------------
TRELLO_API_KEY=
TRELLO_TOKEN=

# --- Cron de synchro horaire (Vercel) — étape 8 ------------------------------
# Secret protégeant /api/cron/sync. Générer une chaîne aléatoire (openssl rand -hex 32).
# Vercel envoie automatiquement « Authorization: Bearer <CRON_SECRET> » aux crons.
CRON_SECRET=

# --- Microsoft 365 / Graph (RDV Outlook + Teams) -----------------------------
# Azure Portal > App registrations > (votre app). OAuth pour créer les événements dans
# le calendrier connecté. Secrets CÔTÉ SERVEUR uniquement (jamais committés / pas NEXT_PUBLIC).
#   MS_CLIENT_ID     = « Application (client) ID »
#   MS_TENANT_ID     = « Directory (tenant) ID » (ou « common » pour multi-tenant)
#   MS_CLIENT_SECRET = Certificates & secrets > New client secret (la VALEUR, pas l'ID)
# URL de redirection à déclarer dans Azure > Authentication > Web > Redirect URIs :
#   local : http://localhost:3000/api/integrations/msgraph/callback
#   prod  : https://pilotage-lynova.vercel.app/api/integrations/msgraph/callback
# Permissions déléguées (Microsoft Graph) : offline_access, User.Read,
# Calendars.ReadWrite, OnlineMeetings.ReadWrite.
MS_CLIENT_ID=
MS_TENANT_ID=
MS_CLIENT_SECRET=
